# Comma-separated paths to media folders
MEDIA_ROOTS=C:\path\to\music,C:\path\to\podcasts

# Gemini API key for AI DJ commentary (optional)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# TTS engine for AI DJ: "cloud" (Google Cloud TTS) or "gemini" (Gemini native voices)
# Defaults to "cloud". "gemini" requires only GEMINI_API_KEY; "cloud" requires ADC credentials.
TTS_ENGINE=cloud

# Voice name when TTS_ENGINE=gemini (default: Kore)
# Options: Kore, Puck, Zephyr, Charon, Fenrir, Aoede, Leda, Orus, and more
TTS_VOICE=Kore

# Server bind address and port
HOST=0.0.0.0
PORT=8054

# Basic auth for control panel (optional)
# Leave empty to disable authentication
AUTH_USERNAME=
# Generate with: uv run streamer-hashpw
AUTH_PASSWORD_HASH=
